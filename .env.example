# Claude Agent SDK 标准 env(SDK 自动识别)
# - 走 Anthropic 官方:ANTHROPIC_BASE_URL 留空、ANTHROPIC_AUTH_TOKEN 填官方 key
# - 走私有网关 / 兼容供应商(GLM / MiniMax 等):BASE_URL 填网关地址、TOKEN 填网关 key
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# Scrivai 框架默认值(可选,供 ModelConfig 与 TrajectoryStore 取默认)
# 例:SCRIVAI_DEFAULT_MODEL=glm-5.1   SCRIVAI_DEFAULT_PROVIDER=glm
SCRIVAI_DEFAULT_MODEL=
SCRIVAI_DEFAULT_PROVIDER=
